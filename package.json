  "type": "module",
  "scripts": {
    "local:base": "webpack-dev-server --config webpack.dev.cjs",
    "build": "webpack --config webpack.prod.cjs",
    "dev": "yarn local:base --stats-error-details --open",
    "test": "cross-env jest --passWithNoTests --no-cache --runInBand",
    "test:watch": "yarn test --watch",
    "test:staged": "yarn test --findRelatedTests",
    "test:ci": "yarn test --coverage",
    "lint": "eslint .",
    "lint:fix": "yarn lint --fix",
    "prepare": "husky"
  },
  "devDependencies": {
